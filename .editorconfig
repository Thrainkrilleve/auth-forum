root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.toml]
indent_style = space
indent_size = 4
# TOML must never have a BOM — pip's TOML parser rejects it
charset = utf-8

[*.py]
indent_style = space
indent_size = 4

[*.html]
indent_style = space
indent_size = 2

[*.{md,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
